# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=dems_db
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/dems_db

# Chapa Configuration
CHAPA_SECRET_KEY=CHAPA-TEST-KEY
CHAPA_PUBLIC_KEY=CHAPA-PUB-TEST-KEY
CHAPA_WEBHOOK_SECRET=your-webhook-secret
BACKEND_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@dems.com
EMAIL_FROM_NAME=DEMS Team
SUPPORT_EMAIL=support@dems.com

# Redis Configuration (for queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Payment Gateway (Mock for now)
PAYMENT_SECRET=test_secret_key

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880